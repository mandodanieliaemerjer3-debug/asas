"use client";
import { useState, useEffect } from "react";
import { useRouter } from "next/navigation";
import { db } from "../../lib/firebase";
import { collection, getDocs, getDoc, doc, addDoc, updateDoc, increment } from "firebase/firestore";
import { useAuth } from "../../contexts/AuthContext";

export default function CheckoutPage() {
  const { user } = useAuth();
  const router = useRouter();
  
  const [cart, setCart] = useState([]);
  const [neighborhoods, setNeighborhoods] = useState([]);
  const [loading, setLoading] = useState(true);
  
  const [selectedBairro, setSelectedBairro] = useState(null);
  const [taxaFinal, setTaxaFinal] = useState(0);
  const [address, setAddress] = useState({ rua: "", numero: "" });

  // 1. Carrega dados do carrinho, bairros e perfil do usuário
  useEffect(() => {
    const init = async () => {
      const savedCart = localStorage.getItem("carrinho");
      if (savedCart) setCart(JSON.parse(savedCart));

      const querySnap = await getDocs(collection(db, "neighborhoods"));
      const bairrosList = querySnap.docs.map(d => ({ id: d.id, ...d.data() }));
      setNeighborhoods(bairrosList);

      if (user) {
        const userRef = doc(db, "users", user.uid);
        const userSnap = await getDoc(userRef);
        if (userSnap.exists()) {
          const userData = userSnap.data();
          if (userData.endereco) {
            setAddress({
              rua: userData.endereco.rua || "",
              numero: userData.endereco.numero || ""
            });
            const bairroSalvo = bairrosList.find(b => b.name === userData.endereco.bairro);
            if (bairroSalvo) executarCalculoLojistico(bairroSalvo);
          }
        }
      }
      setLoading(false);
    };
    init();
  }, [user]);

  // 2. Cálculo de Frete Dinâmico (Preço Base / NP + Taxa Bairro)
  const executarCalculoLojistico = async (bairro) => {
    setSelectedBairro(bairro);
    let taxaFixaBairro = bairro.fee || 0;
    let valorRateioLinha = 0;

    if (bairro.linhaId) {
      const refLinha = doc(db, "lines", String(bairro.linhaId));
      const snapLinha = await getDoc(refLinha);
      
      if (snapLinha.exists()) {
        const dados = snapLinha.data();
        const base = dados.basePrice || 0;
        const pedidosAtivos = dados.np || 1; // Proteção contra divisão por zero
        
        // Matemática Direta: Valor da Linha dividido pelo número de pedidos
        valorRateioLinha = Math.ceil(base / pedidosAtivos);
      }
    }
    setTaxaFinal(taxaFixaBairro + valorRateioLinha);
  };

  const subtotal = cart.reduce((acc, item) => acc + item.price, 0);
  const totalGeral = subtotal + taxaFinal;

  // 3. Gravação do Pedido e Atualização do NP
  const confirmarPedido = async () => {
    if (!selectedBairro || !address.rua) return alert("Verifique o endereço.");
    if (cart.length === 0) return alert("Carrinho vazio!");
    
    setLoading(true);
    try {
      const linhaFinal = selectedBairro.linhaId ? String(selectedBairro.linhaId) : "0";
      const idLoja = cart[0].restaurantId || "rest_1"; 

      // ATUALIZAÇÃO DO NP: Aumenta o contador na linha correspondente
      if (linhaFinal !== "0") {
        const refLinha = doc(db, "lines", linhaFinal);
        await updateDoc(refLinha, {
          np: increment(1)
        });
      }

      const novoPedido = {
        restaurantId: idLoja,
        clienteNome: user?.displayName || "Cliente Mogu",
        clienteId: user?.uid || "anonimo",
        criadoEm: new Date().toISOString().split('T')[0],
        endereco: { 
          ...address, 
          bairro: selectedBairro.name,
          linhaId: linhaFinal 
        },
        itens: cart,
        status: "Pendente",
        pago: false,
        valores: { 
          subtotal, 
          taxaEntrega: taxaFinal, 
          total: totalGeral 
        }
      };

      const docRef = await addDoc(collection(db, "orders"), novoPedido);
      localStorage.removeItem("carrinho");
      router.push(`/pagamento/${docRef.id}`); 
    } catch (e) {
      console.error(e);
      alert("Erro ao salvar.");
      setLoading(false);
    }
  };

  if (loading) return <div className="p-10 text-center font-black italic animate-pulse text-zinc-300 uppercase">Sincronizando...</div>;

  return (
    <div className="min-h-screen bg-gray-50 max-w-md mx-auto p-4 font-sans pb-32">
      <header className="mb-6 flex items-center gap-4">
        <button onClick={() => router.back()} className="text-2xl font-bold">❮</button>
        <h1 className="font-black italic uppercase text-xl text-zinc-900 tracking-tighter">Revisar Pedido</h1>
      </header>

      <section className="bg-white p-6 rounded-[35px] shadow-sm border border-zinc-100 space-y-4">
        <div>
          <label className="text-[10px] font-black uppercase text-zinc-400 ml-2 italic">Local de Entrega</label>
          <select 
            value={selectedBairro?.id || ""}
            onChange={(e) => {
              const b = neighborhoods.find(nb => nb.id === e.target.value);
              if (b) executarCalculoLojistico(b);
            }}
            className="w-full p-4 bg-zinc-50 rounded-2xl font-bold border-none text-zinc-800"
          >
            <option value="">Selecione o Bairro...</option>
            {neighborhoods.map(b => (
              <option key={b.id} value={b.id}>{b.name}</option>
            ))}
          </select>
        </div>

        <div className="grid grid-cols-3 gap-2">
          <div className="col-span-2">
            <label className="text-[10px] font-black uppercase text-zinc-400 ml-2 italic">Rua</label>
            <input type="text" value={address.rua} onChange={e => setAddress({...address, rua: e.target.value})} className="w-full p-4 bg-zinc-50 rounded-2xl border-none text-sm font-bold text-zinc-800" />
          </div>
          <div>
            <label className="text-[10px] font-black uppercase text-zinc-400 ml-2 italic">Nº</label>
            <input type="text" value={address.numero} onChange={e => setAddress({...address, numero: e.target.value})} className="w-full p-4 bg-zinc-50 rounded-2xl border-none text-sm font-bold text-center text-zinc-800" />
          </div>
        </div>
      </section>

      <section className="mt-6 bg-white p-8 rounded-[35px] border border-zinc-100 shadow-sm">
        <div className="flex justify-between items-center mb-2">
          <span className="text-zinc-400 font-bold text-xs uppercase italic">Subtotal</span>
          <span className="font-bold text-zinc-800">R$ {subtotal.toFixed(2)}</span>
        </div>
        <div className="flex justify-between items-center mb-6">
          <span className="text-zinc-400 font-bold text-xs uppercase italic">Taxa de Entrega</span>
          <span className="font-black text-red-600 italic">R$ {taxaFinal.toFixed(2)}</span>
        </div>
        <div className="border-t border-dashed border-zinc-100 pt-6 flex justify-between items-center">
          <span className="font-black uppercase italic text-xl text-zinc-900 tracking-tighter">Total</span>
          <span className="font-black text-3xl text-zinc-900 tracking-tighter">R$ {totalGeral.toFixed(2)}</span>
        </div>
      </section>

      <div className="fixed bottom-0 left-0 right-0 p-4 bg-white/80 backdrop-blur-md max-w-md mx-auto">
        <button onClick={confirmarPedido} className="w-full bg-zinc-950 text-white py-6 rounded-[30px] font-black uppercase italic shadow-2xl active:scale-95 transition-transform">
          Ir para o Pagamento ➔
        </button>
      </div>
    </div>
  );
}